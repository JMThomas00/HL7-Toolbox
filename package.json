{
  "name": "hl7-message-creator-electron",
  "version": "1.0.0",
  "description": "HL7 Message Creator - Desktop application for creating and editing healthcare HL7 messages",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "docker:build": "docker build -t hl7-message-creator .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/data:/app/data hl7-message-creator"
  },
  "keywords": [
    "hl7",
    "healthcare",
    "message",
    "creator",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "papaparse": "^5.4.1"
  },
  "build": {
    "appId": "com.hl7messagecreator.app",
    "productName": "HL7 Message Creator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "data/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
